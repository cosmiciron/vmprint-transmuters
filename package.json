{
  "name": "vmprint-transmuters-workspace",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "dev-cli",
    "markdown-core",
    "mkd-mkd",
    "mkd-academic",
    "mkd-literature",
    "mkd-manuscript",
    "mkd-screenplay",
    "mkd-zh-manuscript"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev:transmute": "tsx dev-cli/src/index.ts"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.4",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@vmprint/context-pdf": "^1.0.2",
    "@vmprint/engine": "^1.3.0",
    "@vmprint/local-fonts": "^1.2.1"
  }
}
