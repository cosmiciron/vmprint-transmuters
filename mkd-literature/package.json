{
  "name": "@vmprint/mkd-literature",
  "version": "1.0.0",
  "description": "Markdown → VMPrint DocumentInput transmuter with literature defaults.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:js": "esbuild src/index.ts --bundle --platform=node --target=node18 --external:@vmprint/contracts --external:@vmprint/markdown-core --outfile=dist/index.js",
    "build:mjs": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --external:@vmprint/contracts --external:@vmprint/markdown-core --outfile=dist/index.mjs",
    "build:dts": "dts-bundle-generator --no-check src/index.ts -o dist/index.d.ts",
    "build": "rimraf dist && npm run build:js && npm run build:mjs && npm run build:dts",
    "dev": "tsx src/index.ts",
    "clean": "rimraf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vmprint/markdown-core": "^1.0.0",
    "@vmprint/contracts": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
